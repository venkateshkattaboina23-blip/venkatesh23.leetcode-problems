import java.util.*;

public class Solution {
    public int[] findEvenNumbers(int[] digits) {
        Set<Integer> resultSet = new TreeSet<>();
        
        int n = digits.length;
        // Try all possible combinations of 3 digits
        for (int i = 0; i < n; i++) {
            for (int j = 0; j < n; j++) {
                for (int k = 0; k < n; k++) {
                    if (i == j || j == k || i == k) continue; // must use distinct indices
                    
                    int num = digits[i] * 100 + digits[j] * 10 + digits[k];
                    
                    // Check conditions: no leading zero, must be even
                    if (digits[i] != 0 && num % 2 == 0) {
                        resultSet.add(num);
                    }
                }
            }
        }
        
        // Convert result set to array
        int[] result = new int[resultSet.size()];
        int idx = 0;
        for (int num : resultSet) {
            result[idx++] = num;
        }
        return result;
    }

    // Quick test
    public static void main(String[] args) {
        Solution sol = new Solution();
        System.out.println(Arrays.toString(sol.findEvenNumbers(new int[]{2,1,3,0})));
        System.out.println(Arrays.toString(sol.findEvenNumbers(new int[]{2,2,8,8,2})));
        System.out.println(Arrays.toString(sol.findEvenNumbers(new int[]{3,7,5})));
    }
}
